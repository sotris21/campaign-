# ─────────────────────────────────────────────────────────────
# Campaign Content Operations Hub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required: SQLite for local dev
DATABASE_URL="file:./dev.db"

# Required: Anthropic Claude API key
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Required for Next.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Switch to PostgreSQL for production
# DATABASE_URL="postgresql://user:password@localhost:5432/campaign_hub"

# ─────────────────────────────────────────────────────────────
# Platform API Integrations (ALL DISABLED UNLESS CONFIGURED)
# These are placeholders. Do not configure unless you have
# proper credentials, platform approval, and legal sign-off.
# ─────────────────────────────────────────────────────────────

# Meta (Facebook/Instagram) Graph API
# REQUIRES: Facebook Developer App, Page Access Token, permissions
# META_APP_ID=""
# META_APP_SECRET=""
# META_PAGE_ACCESS_TOKEN=""
# META_PAGE_ID=""

# TikTok Content Posting API
# REQUIRES: TikTok Developer account, app approval, OAuth token
# TIKTOK_CLIENT_KEY=""
# TIKTOK_CLIENT_SECRET=""
# TIKTOK_ACCESS_TOKEN=""

# Buffer API (for scheduling export)
# REQUIRES: Buffer account and API key
# BUFFER_API_KEY=""
# BUFFER_PROFILE_IDS=""

# ─────────────────────────────────────────────────────────────
# File Storage (local dev uses /public/uploads)
# For production, configure one of these:
# ─────────────────────────────────────────────────────────────

# Vercel Blob (recommended for Vercel deployments)
# BLOB_READ_WRITE_TOKEN=""

# AWS S3
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_BUCKET_NAME=""

# Cloudflare R2
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""

# ─────────────────────────────────────────────────────────────
# Rate Limiting (optional, defaults used if not set)
# ─────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=5
